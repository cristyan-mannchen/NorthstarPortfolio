# Public browser configuration
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only configuration — never prefix these with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=generate-a-long-random-value

# Optional future provider for listed stocks and ETFs
MARKET_DATA_API_KEY=

# Optional AI-assisted import inference (server-only). The importer remains
# functional without these and never exposes the key to the browser.
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
